# Copy to `.env` and tweak. docker-compose picks them up automatically.
#
# ── Host port mapping (direct access) ────────────────────────────────
BACKEND_PORT=31777
FRONTEND_PORT=31778

# Bind address for the host port mapping. For local dev keep 0.0.0.0;
# for public deployment behind the bundled nginx proxy, set both to
# 127.0.0.1 so the upstream containers are not directly reachable
# from the internet.
BACKEND_BIND=0.0.0.0
FRONTEND_BIND=0.0.0.0

# ── nginx reverse proxy (--profile proxy) ────────────────────────────
# Used only when you start with `make compose-up-proxy`.
HTTP_PORT=80
HTTPS_PORT=443

# ── Backend runtime tuning (see src/backend/runtime/) ────────────────
POOL_WORKERS=8
POOL_QUEUE=4096
POOL_FAST_THRESHOLD=4096
GOGC_TARGET=300
GOMAXPROCS=0
JSON_INDENT=0

# ── Container resource caps ──────────────────────────────────────────
BACKEND_CPUS=2.0
BACKEND_MEMORY=512M
FRONTEND_CPUS=1.0
FRONTEND_MEMORY=512M
